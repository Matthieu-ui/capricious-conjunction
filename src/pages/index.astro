---
import PageLayout from "@/layouts/Base";
import PostPreview from "@/components/blog/PostPreview";
import SocialList from "@/components/SocialList";
import { sortMDByDate } from "@/utils";
import type { Post } from "@/data/posts";
const MAX_POSTS = 10;
const allPosts = await Astro.glob<Post>("./posts/*.mdx");
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);
// import Gallery from "../components/react/Gallery.jsx";
---

<PageLayout meta={{ title: "Home" }}>
  <section class="mb-10">
    <h1 class="title text-2xl mb-3">Matthieu Felker</h1>
    <p class="opacity-60 text-sm mb-5">Web & Systems Developer · Data Analytics · Automation</p>
    <p class="mb-6">
      I bridge software, construction, and business. At <strong>Uresco Construction Materials</strong>, I build full-stack tools for warehouse management, inventory, and sales — while also exploring Web3 on the Hedera network.
    </p>
    <SocialList />
  </section>

  <section class="mb-10">
    <h2 class="title mb-3 text-lg">Now</h2>
    <ul class="space-y-2 text-sm opacity-80">
      <li>→ Geolocation-based 3D inventory visualization for lumber & materials</li>
      <li>→ Warehouse management system tooling at Uresco</li>
      <li>→ Open source on <a class="hover:underline" href="https://github.com/matthieu-ui" target="_blank" rel="noopener noreferrer">GitHub</a></li>
    </ul>
  </section>

  {allPostsByDate.length > 0 && (
    <section>
      <h2 class="title mb-4 text-lg">Posts</h2>
      <ul class="space-y-4">
        {allPostsByDate.map((p) => (
          <li>
            <PostPreview post={p} />
          </li>
        ))}
      </ul>
    </section>
  )}
</PageLayout>
